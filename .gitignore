# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
# the worktree symlink form of the same dir (worktree.symlinkDirectories)
/.next
/out/

# production
/build

# misc
.DS_Store
*.pem

# user-uploaded evidence photos (menu snaps) — runtime data, not source
/public/uploads

# seed-enrichment batch state (resumable batch runs)
/.enrich-batch

# generated per-run site-triage kill audit (operator reviews locally; not source)
/docs/*-killed-venues.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep real secrets out, but the example/config contract IS committed
.env*
!.env.example

# vercel
.vercel

# local watermark for push:prod (last-applied timestamp; machine-specific runtime state)
.push-prod-state.json

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / IDE
.idea/
*.swp

# OS junk
Thumbs.db
Desktop.ini

# local Claude Code state (settings, memory, worktrees — per-user, not shared)
.claude/

# Project datasets we do NOT redistribute — curated/scraped venue data.
# Kept out of the repo for anti-scrape + unresolved seed-data licensing
# (see CONTRIBUTING.md#data-and-licensing). Public boundary GeoJSON
# (council districts / neighborhoods) stays tracked so clones/CI work.
/data/*.json
/data/**/*.json
/data/*.csv
# Curated removal list IS tracked — no licensed/scrapeable HH data, and prod
# applies it via `pnpm remove:venues` after a git pull.
!/data/curated-venue-removals.json

STEVEN_GITHUB.md1
pnpm-lock.yaml
# git worktrees (isolated workspaces)
.worktrees/

# Per-run escalation shortlists emitted by reextract:stubs:free (regenerated output, not source)
/docs/hh-escalation-*.json
.superpowers/

# Transient per-run audit/report outputs (regenerable; keep them out of git).
# Durable docs (runbooks, current diagnosis, superpowers/ specs) are committed normally.
docs/quality-audit-*
docs/provenance-audit-*
docs/*-data-audit-*
docs/*-discovery-drops.*
docs/*-discovery-review-*
docs/*-hh-signal-scan-*
docs/*-no-hh-diagnosis-*
docs/*-escalation-review-*
docs/*-escalation-review.csv
docs/hidden-hh-review-*
docs/regate-*
docs/meal-special-review-*
docs/suspect-hh-review-*
docs/*-gate-review.csv
docs/*-stubs-review.csv
docs/audit-escalation/
docs/audits/

# Transient GSC report outputs (regenerated by gsc:pull; not source)
tmp/
/.recall-state

# DB dumps / snapshots — never commit (contain operational data); regenerable via pg_dump.
# Schema migrations under db/migrations/ stay tracked.
/happyhourfriends-dump-*.sql
/hh-pre-reconcile-*.sql
/*.dump

# Scratch capture that should never be committed
/video-script.md

# Local-only, private working copies (e.g. prod-topology design docs kept for reference,
# not published). Anything here stays on-disk but out of git.
/local-only/
