# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# user-uploaded evidence photos (menu snaps) — runtime data, not source
/public/uploads

# seed-enrichment batch state (resumable batch runs)
/.enrich-batch

# generated per-run site-triage kill audit (operator reviews locally; not source)
/docs/*-killed-venues.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep real secrets out, but the example/config contract IS committed
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# editor / IDE
.idea/
*.swp

# OS junk
Thumbs.db
Desktop.ini

# local Claude Code settings (per-user permissions; not shared)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Project datasets we do NOT redistribute — curated/scraped venue data.
# Kept out of the repo for anti-scrape + unresolved seed-data licensing
# (see CONTRIBUTING.md#data-and-licensing). Public boundary GeoJSON
# (council districts / neighborhoods) stays tracked so clones/CI work.
/data/*.json
/data/**/*.json
/data/*.csv

STEVEN_GITHUB.md1
# git worktrees (isolated workspaces)
.worktrees/

# Per-run escalation shortlists emitted by reextract:stubs:free (regenerated output, not source)
/docs/hh-escalation-*.json
