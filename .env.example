# ── Database ──────────────────────────────────────────────────────────────────
# Local dev uses docker-compose (postgis/postgis:16). Production = DO Managed PG.
DATABASE_URL=postgresql://hhf:hhf@localhost:5432/happyhourfriends

# ── Anthropic (AI moderation pipeline) ──────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_CLASSIFIER=claude-haiku-4-5
ANTHROPIC_MODEL_VERIFIER=claude-sonnet-4-6
ANTHROPIC_MONTHLY_CAP_CENTS=2000
ANTHROPIC_WARNING_THRESHOLD_CENTS=1500

# ── Google Places (discovery + enrichment) ──────────────────────────────────────
GOOGLE_PLACES_API_KEY=
# Places is the other paid API and dominates cost at scale — give it its own cap.
GOOGLE_PLACES_MONTHLY_CAP_CENTS=5000
# Google Cloud Vision API key (SafeSearch) for upload image moderation. Enable the
# Vision API on the same project; a Vision-restricted key is recommended.
GOOGLE_VISION_API_KEY=

# ── Captcha (Cloudflare Turnstile — free, unlimited) ────────────────────────────
# Local dev: Cloudflare always-pass test keys exercise the real widget without an account.
# site=1x00000000000000000000AA  secret=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Evidence photo uploads (menu snaps that stand in for a source URL) ──────────
# Optional. Defaults write to ./public/uploads/evidence and serve at /uploads/evidence.
# On multi-node / object storage, point these at a mounted volume or swap evidenceStore
# for DO Spaces. The directory is gitignored.
EVIDENCE_UPLOAD_DIR=
EVIDENCE_PUBLIC_BASE=

# ── Email (Resend) ──────────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=help@friend.happyhourfriends.com

# ── Admin auth (Firebase) ───────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the service-account private key with literal \n escapes, in quotes.
FIREBASE_PRIVATE_KEY=
# Comma-separated allowlist of admin emails.
ADMIN_EMAIL=
# Dev-only: bypass Firebase admin auth on localhost. NEVER set in production.
DEV_ADMIN_EMAIL=

# ── Observability ───────────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Site ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://happyhourfriends.com

# ── Cache revalidation ──────────────────────────────────────────────────────────
# Shared secret for the internal /api/internal/revalidate endpoint that the apply
# engine calls to refresh cached pages after a venue change. REQUIRED in production
# (the endpoint fails closed without it); skipped in dev. Generate one, e.g.
#   openssl rand -hex 32
REVALIDATE_SECRET=
# Optional override for the origin the engine POSTs revalidations to. Defaults to the
# local Next server (http://127.0.0.1:$PORT) — only set this if the app listens
# somewhere other than 127.0.0.1:3000.
INTERNAL_BASE_URL=

# Google Search Console (gsc:pull) — service-account read access to the property.
# See docs/superpowers/specs/2026-06-19-gsc-visibility-check-design.md for setup.
GSC_SERVICE_ACCOUNT_KEY_PATH=
GSC_PROPERTY=sc-domain:happyhourfriends.com
